# =============================================================================
# AI DevOps Engine — Environment Configuration Template
# =============================================================================
# Copy this file to .env in the project root, then fill in your values.
# Docker Compose reads .env automatically from the project root directory.
# Every variable has a sensible default — only the ones marked (required)
# must be set for the system to function.
# =============================================================================

# --- Database (all optional — defaults work for local Docker Compose) ---
POSTGRES_DB=ai_devops_db
POSTGRES_USER=devops_admin
POSTGRES_PASSWORD=SecretSecurePasswordChangeMe
POSTGRES_HOST=postgres-db
POSTGRES_PORT=5432

# --- Redis ---
REDIS_HOST=redis-broker
REDIS_PORT=6379
REDIS_DB=0

# --- Django (required: DJANGO_SECRET_KEY, FERNET_KEY) ---
DJANGO_SECRET_KEY=generate-a-strong-random-key-here
DJANGO_DEBUG=False
DJANGO_PORT=8000
FERNET_KEY=generate-a-fernet-key-here
ALLOWED_HOSTS=*

# --- Data Retention ---
AUDIT_RETENTION_DAYS=90

# --- GitHub App (required) ---
GITHUB_APP_IDENTIFIER=your-github-app-id
GITHUB_APP_PRIVATE_KEY_PATH=/app/certs/github_app.pem
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# --- Certificates (mount path for GitHub App .pem) ---
CERTS_PATH=./certs

# --- Ingestion Service ---
INGESTION_PORT=3000

# --- FastAPI Brain / AI (required: OPENROUTER_API_KEY) ---
FASTAPI_PORT=8010
OPENROUTER_API_KEY=sk-or-v1-your-key-here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DATA_COLLECTION=deny
SLACK_ANALYSIS_WEBHOOK_URL=

# --- Celery ---
CELERY_LOG_LEVEL=info
CELERY_CONCURRENCY=2

# --- Billing Collector (required for AWS cost collection) ---
BILLING_API_GATEWAY=http://django-dashboard:8000
INTERNAL_BILLING_TOKEN=LocalSecretInternalTokenBetweenServices
COLLECT_INTERVAL_SECONDS=86400
BILLING_ORG_NAME=default
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# =============================================================================
# PAYMENT GATEWAY
# =============================================================================
# Options: stripe (default), manual
# Bring your own: implement PaymentBackend ABC in payment_backends.py
PAYMENT_GATEWAY=stripe

# Stripe (used when PAYMENT_GATEWAY=stripe):
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=
STRIPE_ENTERPRISE_PRICE_ID=price_placeholder
STRIPE_SUCCESS_URL=http://localhost/dashboard/
STRIPE_CANCEL_URL=http://localhost/

# Manual/invoice (used when PAYMENT_GATEWAY=manual):
PAYMENT_MANUAL_REDIRECT_URL=/dashboard/

# =============================================================================
# EMAIL DELIVERY
# =============================================================================
# Options: sendgrid, smtp, console (default), log
# Bring your own: implement EmailBackend ABC in email_backends.py
EMAIL_BACKEND=console

# From address/name (used by all backends):
EMAIL_FROM_ADDRESS=billing@yourstartupdomain.com
EMAIL_FROM_NAME=AI DevOps Billing

# SendGrid (used when EMAIL_BACKEND=sendgrid):
SENDGRID_API_KEY=

# SMTP (used when EMAIL_BACKEND=smtp):
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_TLS=true
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# =============================================================================
# SLACK
# =============================================================================
# Two separate webhooks:
#   SLACK_ALERTS_WEBHOOK_URL  → celery-worker crash alerts
#   SLACK_ANALYSIS_WEBHOOK_URL → fastapi-brain AI analysis results
SLACK_ALERTS_WEBHOOK_URL=

# =============================================================================
# CADDY REVERSE PROXY
# =============================================================================
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
CADDYFILE_PATH=./Caddyfile
